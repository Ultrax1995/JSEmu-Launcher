<Page x:Class="H1Emu_Launcher.SettingsPages.About"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:H1Emu_Launcher.SettingsPages"
      mc:Ignorable="d"
      UseLayoutRounding="True"
      d:DesignWidth="735"
      Title="About"
      FontFamily="Bahnschrift"
      FontSize="16"
      Foreground="FloralWhite">

    <Page.Resources>
        <ResourceDictionary>
            <!-- Load dictionary into xaml resources just so we can see on the designer -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="..\Language\StringResources.en-EN.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Border Background="{DynamicResource DarkerColour}"
            UseLayoutRounding="True"
            VerticalAlignment="Top"
            CornerRadius="0,5,5,5">

        <Grid>

            <!-- Grainy texture -->
            <Grid.Background>
                <ImageBrush ImageSource="..\Resources\Grain.png"
                            Opacity="0.5"
                            TileMode="Tile"
                            ViewportUnits="Absolute"
                            Viewport="0,0,512,512"/>
            </Grid.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1">

                    <!-- List of everyone who helped on the project -->
                    <!-- Lead development -->
                    <TextBlock Margin="20"
                               FontSize="18"
                               Foreground="#FFED1C24"
                               TextDecorations="Underline"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Text="{DynamicResource item126}"
                               Style="{DynamicResource TextBlockStyle}"/>

                    <TextBlock Margin="60,0,60,0"
                               Foreground="FloralWhite"
                               FontWeight="Light"
                               Text="• Ultrax • Eric • Avcio • Kentin • JSON •"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Style="{DynamicResource TextBlockStyle}"/>

                    <!-- Divider -->
                    <Rectangle Margin="20,20,20,0"
                               Height="1"
                               Fill="{DynamicResource LighterColour}">

                        <Rectangle.Effect>
                            <DropShadowEffect BlurRadius="8"
                                              Direction="-90"
                                              RenderingBias="Quality"
                                              ShadowDepth="1"
                                              Opacity="0.3"/>
                        </Rectangle.Effect>
                    </Rectangle>

                    <!-- Developers -->
                    <TextBlock Margin="0,20,0,20"
                               FontSize="18"
                               Foreground="#FFED1C24"
                               TextDecorations="Underline"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Text="{DynamicResource item127}"
                               Style="{DynamicResource TextBlockStyle}"/>

                    <TextBlock Margin="60,0,60,0"
                               Foreground="FloralWhite"
                               FontWeight="Light"
                               Text="• Noctiamor • Johnoclock • looc343 •"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Style="{DynamicResource TextBlockStyle}"/>

                    <!-- Divider -->
                    <Rectangle Margin="20,20,20,0"
                               Height="1"
                               Fill="{DynamicResource LighterColour}">

                        <Rectangle.Effect>
                            <DropShadowEffect BlurRadius="8"
                                              Direction="-90"
                                              RenderingBias="Quality"
                                              ShadowDepth="1"
                                              Opacity="0.3"/>
                        </Rectangle.Effect>
                    </Rectangle>

                    <!-- Thank to community message -->
                    <TextBlock Margin="60,20,60,20"
                               Foreground="FloralWhite"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontWeight="Light"
                               Text="{DynamicResource item132}"
                               Style="{DynamicResource TextBlockStyle}"/>

                    <!-- Divider -->
                    <Rectangle Margin="20,0,20,0"
                               Height="1"
                               Fill="{DynamicResource LighterColour}">

                        <Rectangle.Effect>
                            <DropShadowEffect BlurRadius="8"
                                              Direction="-90"
                                              RenderingBias="Quality"
                                              ShadowDepth="1"
                                              Opacity="0.3"/>
                        </Rectangle.Effect>
                    </Rectangle>

                    <!-- Launcher made by Noctiamor message -->
                    <TextBlock Margin="60,20,60,20"
                               Foreground="FloralWhite"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontWeight="Light"
                               Text="{DynamicResource item169}"
                               Style="{DynamicResource TextBlockStyle}"/>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Page>